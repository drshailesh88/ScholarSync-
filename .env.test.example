# Test Environment Variables
# Copy to .env.test and fill in values

# Clerk Testing Token (recommended for CI)
# Generate from Clerk Dashboard → Testing → Tokens
# See: https://clerk.com/docs/testing/overview
CLERK_TESTING_TOKEN=

# Test User Credentials (fallback if no testing token)
TEST_USER_EMAIL=test@scholarsync.dev
TEST_USER_PASSWORD=

# Base URL for tests (defaults to localhost:5173)
BASE_URL=http://localhost:5173
